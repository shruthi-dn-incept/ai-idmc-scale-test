.env
.env.*
!.env.example

# Snowflake key-pair credentials (private + public) — never commit
*.p8
snowflake_scale_test_rsa_key*
rsa_key.*

# VS Code MCP config — may contain interpolation refs but we keep it untracked
# so anyone cloning the repo starts from .vscode/mcp.example.json.
.vscode/mcp.json

# Per-user Claude Code state
.claude/settings.local.json

# Python
__pycache__/
tests/__pycache__/
*.pyc
.venv/
venv/

# Vendor docs: only the index is tracked. The PDFs/ZIPs are vendor-owned
# and not redistributable, and the zips total hundreds of MB anyway.
docs/*
!docs/*.md
!docs/.gitkeep

# Local config for dq_monitor alerts (no IDMC API exposes alert registration;
# this file is consumed only by sibling cron/agent processes).
.dq_monitor_alerts.json

# Mac noise
.DS_Store

# Logs and runtime cache
logs/
.scan_cache/
.mcp.json
*.log

# Scale-pipeline generated state/outputs (regenerable by run_scale_pipeline.py)
taxonomy.json
colterm_map.json
term_ids.json
rule_map.json
system_dataset.json
stats.json
mcc_scan_jobs.json
# Generated bulk-import file (1.4 MB, regenerable); keep the source template tracked
templates/CDGC_DQRO_FULL.xlsx
