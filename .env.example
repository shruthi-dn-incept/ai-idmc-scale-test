# ── IDMC Credentials ──────────────────────────────────────────────────────────
# Your Informatica Cloud login email
IDMC_USER=you@yourcompany.com

# Your Informatica Cloud login password
IDMC_PASS=YourPassword123

# Login host — do not change unless on a non-US pod
IDMC_LOGIN_HOST=dm-us.informaticacloud.com

# Organisation ID — found in IDMC → Admin → Organisation Details
IDMC_ORG_ID=your_org_id_here

# IDMC server URL — update pod suffix (usw3, use4, etc.) to match your org
IDMC_SERVER_URL=https://usw3.dm-us.informaticacloud.com/saas

# FRS (CDQ rule spec) host — same pod as IDMC_SERVER_URL
IDMC_FRS_HOST=usw3.dm-us.informaticacloud.com

# DQ Cloud host — check IDMC → Admin → Pod Information
IDMC_DQ_HOST=usw1-dqcloud.dmp-us.informaticacloud.com

# Identity host — same as IDMC_LOGIN_HOST in most cases
IDMC_IDENTITY_HOST=dm-us.informaticacloud.com

# ── CDGC API ───────────────────────────────────────────────────────────────────
# CDGC REST API base URL — do not add a trailing slash
CDGC_API_BASE=https://cdgc-api.dm-us.informaticacloud.com

# ── CDQ Folder (Rule Specifications) ─────────────────────────────────────────
# Folder ID where rule specs are created in CDQ
# Find it in CDQ → Rule Specification folder → URL bar
CDQ_FOLDER_ID=your_cdq_folder_id_here

# Display name of the folder (used for logging only)
CDQ_FOLDER_NAME=Rule_Specification

# ── Anthropic API ──────────────────────────────────────────────────────────────
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── CDQ Mapping Task (optional — only needed for profile_and_govern) ──────────
# Connection ID used for DQ mapping tasks
IDMC_DQ_CONNECTION_ID=your_connection_id

# Runtime environment ID for DQ jobs
IDMC_DQ_RUNTIME_ENV_ID=your_runtime_env_id

# Template mapping ID for DQ execution (the M_DQ_Generic parameterized mapping).
# MUST be a CURRENTLY-PUBLISHED mapping visible to this org — a stale, deleted,
# or unpublished id makes the Data Quality step fail per rule with
# "mapping lookup HTTP 403 ... REPO_36004" and the MCC scan step reports "skipped".
# Accepts the v2 native id (010...) or the v3 catalog GUID. Verify with:
#   python probe_dq_template.py   (expects HTTP 200 + a parameter list)
IDMC_DQ_TEMPLATE_MAPPING_ID=your_template_mapping_id

# Snowflake schema path for DQ test tables (format: DATABASE/SCHEMA)
IDMC_DQ_SCHEMA_PATH=YOUR_DB/DQ_TEST

# ── Azure deployment (read by deploy/*.ps1) ───────────────────────────────────
# For a NEW Azure account, set these — the deploy scripts read them from here so
# you don't edit each script. Any left blank fall back to the script defaults.
# AZURE_SUBSCRIPTION_ID: az account show --query id -o tsv
AZURE_SUBSCRIPTION_ID=your_subscription_id
# AZURE_TENANT_ID: az account show --query tenantId -o tsv
AZURE_TENANT_ID=your_tenant_id
AZURE_RESOURCE_GROUP=govtest-scale-rg
AZURE_LOCATION=eastus
# ACR name must be GLOBALLY UNIQUE across all of Azure (lowercase, no hyphens)
AZURE_ACR_NAME=your_unique_acr_name
# VM size for the Secure Agent. New/trial subs often cap at 4 vCPUs — if
# 'az vm create' hits a quota error, use Standard_D4s_v3 (or request a quota bump).
AZURE_VM_SIZE=Standard_D8s_v3

# ── Auto-managed (do not set manually) ────────────────────────────────────────
# These are written automatically by the servers at runtime. Leave blank.
IDMC_SESSION_ID=
IDMC_JWT=
IDMC_JWT_MINTED_AT=
IDMC_V3_SESSION_ID=
IDMC_V3_BASE_URL=
